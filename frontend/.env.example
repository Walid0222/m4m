# Laravel API base URL (optional; defaults to http://localhost:8000/api/v1)
# Use /api/v1 when using Vite proxy to Laravel.
VITE_API_BASE_URL=
VITE_API_URL=http://localhost:8000/api/v1
VITE_GOOGLE_CLIENT_ID=

# Laravel Reverb (real-time WebSocket) – must match backend .env
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
